			<DynamicEvents>
				<DynamicEventClass>
					<Id>1776837168745</Id>
					<Name><![CDATA[DepartureEvent]]></Name>
					<Description><![CDATA[The dynamic event DepartureEvent schedules a plane’s departure by removing the flight from the agent population that contains upcoming flights. Use the figure below to help you set up the event.
17]]></Description>
					<X>700</X><Y>1600</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[flight]]></Name>
						<Type><![CDATA[Flight]]></Type>
					</Parameter>
					<Action><![CDATA[remove_flights(flight)]]></Action>
				</DynamicEventClass>
				<DynamicEventClass>
					<Id>1776837181439</Id>
					<Name><![CDATA[BoardingEvent]]></Name>
					<X>700</X><Y>1500</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[flight]]></Name>
						<Type><![CDATA[Flight]]></Type>
					</Parameter>
					<Action><![CDATA[startBoarding(flight);
create_DepartureEvent( boardingTime, flight)]]></Action>
				</DynamicEventClass>
			</DynamicEvents>
			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1776772002702</Id>
					<Name><![CDATA[setUpPassenger]]></Name>
					<X>702.4</X><Y>1201.2</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[ped]]></Name>
						<Type><![CDATA[Passenger]]></Type>
					</Parameter>
					<Body><![CDATA[ped.business = randomTrue(0.15);

Flight f;


do 
{ f =  flights.random(); }
while (dateToTime(f.departureTime) - boardingTime < time() );

ped.flight = f;
f.passengers.add(ped);]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1776837628289</Id>
					<Name><![CDATA[startBoarding]]></Name>
					<Description><![CDATA[The if operator checks the specified condition. If the selected flight’s boarding is taking place, we schedule the departure, and allow boarding by calling the startBoarding function (passing the reference to this flight as the function argument value). Otherwise, we schedule BoardingEvent.]]></Description>
					<X>900</X><Y>1600</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[flight]]></Name>
						<Type><![CDATA[Flight]]></Type>
					</Parameter>
					<Body><![CDATA[for (Passenger p : flight.passengers)
{
	pedWait1.free(p);
}]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1776838437394</Id>
					<Name><![CDATA[planBoardings]]></Name>
					<X>900</X><Y>1500</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[for (Flight f : flights)
{
	double timeBeforeBoarding = dateToTime(f.departureTime) - boardingTime;
	
	if (timeBeforeBoarding >= 0)
	{
		create_BoardingEvent(timeBeforeBoarding, f);
	}
	else{
		create_DepartureEvent(dateToTime(f.departureTime), f);
		startBoarding(f);
	}
}]]></Body>
				</Function>
			</Functions>
